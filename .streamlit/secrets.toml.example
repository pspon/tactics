# Tactician – Streamlit Secrets Template
# ----------------------------------------
# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is excluded from git and must NEVER be committed.
#
# Each setting can also be supplied as an environment variable (same key name)
# for Docker / non-Streamlit deployments.

# ---------------------------------------------------------------------------
# Private card repository
# ---------------------------------------------------------------------------
# The app clones this repo at startup when output/cards/ is empty.
# Omit these two keys if you supply cards via a volume mount instead.
#
# CARDS_GITHUB_TOKEN  – Personal Access Token with read-only `repo` scope.
#                       Generate one at: GitHub → Settings → Developer settings
#                       → Personal access tokens → Fine-grained tokens
#                       (grant "Contents: Read" on the private repo only).
#
# CARDS_REPO          – Repository in "owner/name" form.
#
# Expected private repo layout:
#   cards/               ← PNG card images   → output/cards/
#   metadata/            ← optional JSON     → output/metadata/
#     card_names.json
#     card_types.json
#
# Docker alternative (no token required):
#   docker run -v /host/path/to/cards:/app/output/cards ...
# ---------------------------------------------------------------------------
CARDS_GITHUB_TOKEN = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CARDS_REPO         = "your-org/tactician-cards"

# ---------------------------------------------------------------------------
# Allowlist of usernames permitted to access the app.
# Only users whose name appears here can log in or create an account.
# Remove this key entirely to allow open self-registration.
#
# Env var equivalent:  ALLOWED_USERS=alice,bob,charlie
# ---------------------------------------------------------------------------
allowed_users = ["alice", "bob", "charlie"]

# ---------------------------------------------------------------------------
# User accounts must still be created via the admin CLI before a listed user
# can log in for the first time:
#
#   python src/manage_users.py create alice
#   python src/manage_users.py list
#   python src/manage_users.py delete alice
# ---------------------------------------------------------------------------
